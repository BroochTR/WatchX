# Cấu hình môi trường WatchX
# Sao chép file này thành .env rồi chỉnh lại theo máy chủ của bạn.

# -----------------------------------------------------------------------------
# BẢO MẬT
# -----------------------------------------------------------------------------

# Khóa bí mật dùng để ký JWT.
# Tạo bằng lệnh: openssl rand -hex 32
# Không dùng giá trị ví dụ khi đưa lên môi trường thật.
SECRET_KEY=thay_bang_chuoi_hex_ngau_nhien_toi_thieu_32_ky_tu

# Khóa dùng chung giữa backend và engine.
# Tạo bằng lệnh: openssl rand -hex 32
WEBHOOK_SECRET=thay_bang_chuoi_hex_ngau_nhien_khac_secret_key

# Chỉ đặt true khi cần debug nhanh ở môi trường local.
ALLOW_WEAK_SECRET=false

# -----------------------------------------------------------------------------
# MẠNG VÀ TRUY CẬP
# -----------------------------------------------------------------------------

# Cổng truy cập giao diện web.
WATCHX_FRONTEND_PORT=8080

# Cổng API backend.
WATCHX_BACKEND_PORT=5005

# Múi giờ cho hệ thống. Hà Nội dùng Asia/Ho_Chi_Minh.
TZ=Asia/Ho_Chi_Minh

# Danh sách domain được phép gọi API, ngăn cách bằng dấu phẩy.
# Để trống nếu chỉ chạy local hoặc muốn backend tự suy ra từ PUBLIC_BASE_URL.
ALLOWED_ORIGINS=

# URL public của WatchX khi chạy sau reverse proxy hoặc tunnel.
# Ví dụ: https://watchx.example.com
PUBLIC_BASE_URL=

# auto: tự nhận HTTP/HTTPS
# true: luôn bật Secure cookie, chỉ dùng khi chạy HTTPS
# false: tắt Secure cookie, chỉ nên dùng khi test local
COOKIE_SECURE=auto

# -----------------------------------------------------------------------------
# CƠ SỞ DỮ LIỆU
# -----------------------------------------------------------------------------

POSTGRES_USER=watchx
POSTGRES_PASSWORD=doi_mat_khau_database
POSTGRES_DB=watchx

# -----------------------------------------------------------------------------
# TĂNG TỐC PHẦN CỨNG
# -----------------------------------------------------------------------------

# false: chạy bằng CPU
# true: bật tăng tốc phần cứng nếu máy chủ đã cấu hình sẵn
HW_ACCEL=false

# Lựa chọn: auto, nvidia, intel, amd
HW_ACCEL_TYPE=auto
